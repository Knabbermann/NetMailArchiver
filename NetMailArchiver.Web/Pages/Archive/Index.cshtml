@page
@model NetMailArchiver.Web.Pages.Archive.IndexModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var token = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div style="padding-top: 50px"></div>
<div class="accordion" id="imapAccordion">
    @foreach (var imapInformation in Model.ImapInformations)
    {
        <div class="accordion-item">
            <h2 class="accordion-header" id="heading_@imapInformation.Id">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_@imapInformation.Id" aria-expanded="false" aria-controls="collapse_@imapInformation.Id">
                    <h2 class="text-info mb-0">@imapInformation.Username</h2>
                </button>
            </h2>
            <div id="collapse_@imapInformation.Id" class="accordion-collapse collapse" aria-labelledby="heading_@imapInformation.Id" data-bs-parent="#imapAccordion">
                <div class="accordion-body">
                    <div class="mb-3">
                        <input type="text" class="form-control search-input" id="searchInput_@imapInformation.Id" placeholder="Search emails..." />
                        <div class="form-check mt-2 mb-2">
                            <input class="form-check-input search-body-checkbox" type="checkbox" id="searchBody_@imapInformation.Id">
                            <label class="form-check-label" for="searchBody_@imapInformation.Id">
                                Search in email body as well
                            </label>
                        </div>
                        <button class="btn btn-info searchEmail" data-imap-id="@imapInformation.Id">
                            <i class="bi bi-search"></i> Search
                        </button>
                        <div class="mt-3 text-center" id="loadingSpinner_@imapInformation.Id" style="display: none;">
                            <div class="spinner-border text-info" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2 text-muted">Searching emails...</p>
                        </div>
                    </div>
                    <div id="emailTable_@imapInformation.Id">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>From</th>
                                    <th>Subject</th>
                                    <th width="120px" class="text-center">Markers</th>
                                    <th class="fst-italic">Action</th>
                                </tr>
                            </thead>
                            <tbody id="emailTableBody_@imapInformation.Id">
                            </tbody>
                        </table>
                        <div class="pagination">
                            <div class="d-flex justify-content-between mt-3">
                                <button class="btn btn-info prevPage" data-imap-id="@imapInformation.Id" disabled>
                                    <i class="bi bi-arrow-left"></i> Previous
                                </button>
                                <span style="padding: 10px">Page: <span id="currentPage_@imapInformation.Id">1</span></span>
                                <button class="btn btn-info nextPage" data-imap-id="@imapInformation.Id">
                                    <i class="bi bi-arrow-right"></i> Next
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
    $(document).ready(function () {
        function loadEmails(imapId, page, pageSize, searchQuery, searchBody) {

            const $tableBody = $('#emailTableBody_' + imapId);
            const $currentPage = $('#currentPage_' + imapId);
            const $prevPage = $('[data-imap-id="' + imapId + '"].prevPage');
            const $nextPage = $('[data-imap-id="' + imapId + '"].nextPage');
            const $spinner = $('#loadingSpinner_' + imapId);
            const $table = $('#emailTable_' + imapId);

            // Show spinner, hide table
            $spinner.show();
            $table.hide();

            $.ajax({
                url: '/Archive/Index?handler=Mails',
                type: 'GET',
                data: { ImapId: imapId, page: page, pageSize: pageSize, searchQuery: searchQuery, searchBody: searchBody },
                success: function (data) {
                    $tableBody.empty();

                    $.each(data.emails, function (index, email) {
                        const hasAttachments = email.attachments && email.attachments.length > 0;
                        const attachmentButton = hasAttachments
                            ? '<button class="btn btn-link downloadAttachment" data-email-id="' + email.id + '">Download Attachments</button>'
                            : '';

                        const favoriteIcon = email.isFavorite 
                            ? '<i class="fas fa-star text-warning"></i>' 
                            : '<i class="far fa-star text-muted"></i>';
                        const followUpIcon = email.isFollowUp 
                            ? '<i class="fas fa-flag text-danger"></i>' 
                            : '<i class="far fa-flag text-muted"></i>';

                        const subjectWithPreview = email.subject + 
                            (email.preview ? '<br><small class="text-muted">' + email.preview + '</small>' : '');

                        $tableBody.append('<tr><td>' + email.date + '</td><td>' + email.from + '</td><td>' + subjectWithPreview + '</td>' +
                            '<td class="text-center">' +
                            '<button class="btn btn-sm btn-link p-1 toggleFavorite" data-email-id="' + email.id + '" title="Favorite">' + favoriteIcon + '</button>' +
                            '<button class="btn btn-sm btn-link p-1 toggleFollowUp" data-email-id="' + email.id + '" title="Follow Up">' + followUpIcon + '</button>' +
                            '</td>' +
                            '<td><button class="btn btn-link openEmail" data-email-id="' + email.id + '">Open</button>' +
                            attachmentButton + '</td></tr>');
                    });

                    $currentPage.text(page);

                    $prevPage.prop('disabled', page <= 1);
                    $nextPage.prop('disabled', !data.hasMorePages);

                    // Hide spinner, show table
                    $spinner.hide();
                    $table.show();
                },
                error: function(xhr, status, error) {
                    console.error('Error loading emails:', error);
                    // Hide spinner, show table even on error
                    $spinner.hide();
                    $table.show();
                }
            });
        }

        $('.accordion-button').on('click', function () {
            const imapId = $(this).attr('data-bs-target').split('_')[1];
            const $currentPage = $('#currentPage_' + imapId);

            $currentPage.text(1);
            loadEmails(imapId, 1, 10, '', false);
        });

        $(document).on('click', '.prevPage', function () {
            const imapId = $(this).data('imap-id');
            const currentPage = parseInt($('#currentPage_' + imapId).text(), 10);
            const searchQuery = $('#searchInput_' + imapId).val();
            const searchBody = $('#searchBody_' + imapId).is(':checked');

            if (currentPage > 1) {
                loadEmails(imapId, currentPage - 1, 10, searchQuery, searchBody);
            }
        });

        $(document).on('click', '.nextPage', function () {
            const imapId = $(this).data('imap-id');
            const currentPage = parseInt($('#currentPage_' + imapId).text(), 10);
            const searchQuery = $('#searchInput_' + imapId).val();
            const searchBody = $('#searchBody_' + imapId).is(':checked');
            loadEmails(imapId, currentPage + 1, 10, searchQuery, searchBody);
        });

        $(document).on('click', '.openEmail', function () {
            const emailId = $(this).data('email-id');
            const url = '/Archive/Index?handler=OpenEmail&emailId=' + emailId;
            window.open(url, '_blank');
        });

        $(document).on('click', '.downloadAttachment', function () {
            const emailId = $(this).data('email-id');
            const url = '/Archive/Index?handler=DownloadAttachment&emailId=' + emailId;
            window.location.href = url;
        });

        $(document).on('click', '.searchEmail', function () {
            const imapId = $(this).data('imap-id');
            const searchQuery = $('#searchInput_' + imapId).val();
            const searchBody = $('#searchBody_' + imapId).is(':checked');
            loadEmails(imapId, 1, 10, searchQuery, searchBody);
        });

        $(document).on('click', '.toggleFavorite', function () {
            const $button = $(this);
            const emailId = $button.data('email-id');

            $.ajax({
                url: '/Archive/Index?handler=ToggleFavorite',
                type: 'POST',
                headers: {
                    'RequestVerificationToken': '@token'
                },
                data: JSON.stringify({ emailId: emailId }),
                contentType: 'application/json',
                success: function (data) {
                    const $icon = $button.find('i');
                    if (data.isFavorite) {
                        $icon.removeClass('far text-muted').addClass('fas text-warning');
                    } else {
                        $icon.removeClass('fas text-warning').addClass('far text-muted');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error toggling favorite:', error);
                }
            });
        });

        $(document).on('click', '.toggleFollowUp', function () {
            const $button = $(this);
            const emailId = $button.data('email-id');

            $.ajax({
                url: '/Archive/Index?handler=ToggleFollowUp',
                type: 'POST',
                headers: {
                    'RequestVerificationToken': '@token'
                },
                data: JSON.stringify({ emailId: emailId }),
                contentType: 'application/json',
                success: function (data) {
                    const $icon = $button.find('i');
                    if (data.isFollowUp) {
                        $icon.removeClass('far text-muted').addClass('fas text-danger');
                    } else {
                        $icon.removeClass('fas text-danger').addClass('far text-muted');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error toggling follow-up:', error);
                }
            });
        });
    });
</script>
